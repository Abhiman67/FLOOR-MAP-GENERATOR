# Backend Environment Variables
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
HOST=127.0.0.1
PORT=5000

# Security - REQUIRED in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# CORS - Comma-separated origins, or * for all (development only)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Base URL for image URLs in API responses (optional, auto-detected from request)
# BASE_URL=http://127.0.0.1:5000

# Dataset Configuration  
DATASET_PATH=./dataset/house_plans_details.csv
IMAGES_PATH=./dataset/images/images

# File Upload Limits
MAX_UPLOAD_SIZE=10485760
